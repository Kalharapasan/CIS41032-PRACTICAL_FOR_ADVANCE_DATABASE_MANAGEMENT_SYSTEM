{StudentID:105, Name:"Ava Miller", Age:14, Grade:9, Section:"B", Marks:92, EnrollmentDate:new Date("2021-01-18"), Status:"Active"},
{StudentID:106, Name:"James White", Age:17, Grade:12, Section:"C", Marks:80, EnrollmentDate:new Date("2018-05-25"), Status:"Graduated"},
{StudentID:107, Name:"Charlotte Lee", Age:15, Grade:10, Section:"A", Marks:87, EnrollmentDate:new Date("2020-08-30"), Status:"Active"},
