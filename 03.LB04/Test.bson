db.Students.find()

db.Students.updateMany(
    {Grade:10},
    {$mul:{Markd:1.05}}
)

db.Students.updateMany(
    {Grade:12},
    {$set:{Status:"Alumni"}}
)

db.Students.updateMany(
    {},
    {$rename:{"Marks":"Score"}}
)


db.Students.updateOne(
    {Name:"Emma Johnson"},
    {$set:{Section:"B"}}
)

db.Students.updateMany(
    {Score:{$gt:90}},
    {$set:{Scholarship:"Yes"}}
)

db.Students.deleteMany(
    {Status:"Graduated"}
)

db.Students.deleteMany(
  {
    Grade: 11,
    EnrollmentDate: { $lt: new Date("2020-01-01") }
  }
)

db.Students.deleteMany(
  {Name:"James White"}
)

db.Students.deleteMany(
  {},
  {$unset:{Scholarship:""}}
)